{
  "name": "@spaceis/sdk",
  "version": "0.1.4",
  "description": "Official JavaScript SDK for SpaceIS shop platform. Zero dependencies, works everywhere.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "browser": "./dist/spaceis.global.js",
  "unpkg": "./dist/spaceis.global.js",
  "jsdelivr": "./dist/spaceis.global.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "spaceis",
    "shop",
    "shop",
    "sdk",
    "api-client",
    "ecommerce",
    "vanilla-js"
  ],
  "author": "SpaceIS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/spaceis-app/spaceis-sdk.git"
  }
}
