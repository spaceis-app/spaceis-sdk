{
  "name": "spaceis-sdk",
  "private": true,
  "type": "module",
  "description": "SpaceIS SDK monorepo — JavaScript SDK + React & Vue bindings",
  "scripts": {
    "build": "pnpm --filter @spaceis/sdk build && pnpm --filter @spaceis/react build && pnpm --filter @spaceis/vue build && pnpm --filter create-spaceis build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "bump-sri": "./scripts/bump-sri.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5",
    "eslint-plugin-vue": "^9.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.0.0",
    "vue-eslint-parser": "^9.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
